{
  "platform": "antigravity",
  "name": "AgentUp PHP",
  "version": "1.0.0",
  "description": "AI-powered PHP backend generator for Google Antigravity",
  "install_path": ".agent/skills/php",
  "config_file": ".agent/skills/php/SKILL.md",
  "search_command": "python3 .agent/skills/php/scripts/search.py",
  "features": {
    "domain_search": true,
    "stack_search": true,
    "arch_system": true,
    "auto_detect": true,
    "persist": true
  },
  "domains": [
    "pattern",
    "package",
    "error",
    "perf",
    "test",
    "security",
    "interface",
    "arch",
    "idiom",
    "anti",
    "tooling",
    "dependency"
  ],
  "stacks": [
    "laravel",
    "symfony",
    "codeigniter",
    "slim",
    "api-platform",
    "livewire",
    "database",
    "queue"
  ],
  "setup": {
    "copy_files": [
      {
        "from": "skills/php",
        "to": ".agent/skills/php"
      }
    ],
    "create_config": {
      "file": ".agent/skills/php/SKILL.md",
      "template": "templates/platforms/antigravity-skill.md"
    }
  }
}
